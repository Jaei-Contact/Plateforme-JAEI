# ============================================================
# JAEI Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Base de données PostgreSQL (fournie par Render) ──────────
DATABASE_URL=postgresql://user:password@host:5432/jaei

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=remplacer_par_une_chaine_aleatoire_longue_et_securisee

# ── Frontend (URL de production) ─────────────────────────────
FRONTEND_URL=https://jaei.org

# ── Email SMTP (Infomaniak) ───────────────────────────────────
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@jaei.org
SMTP_PASS=mot_de_passe_boite_infomaniak
SMTP_FROM=noreply@jaei.org
ADMIN_EMAIL=redaction@jaei.org

# ── Cloudinary (stockage PDFs et avatars) ────────────────────
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ── Stripe (paiements) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUBMISSION_FEE_XOF=200000

# ── OpenAI (IA) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
